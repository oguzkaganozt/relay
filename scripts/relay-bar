#!/usr/bin/env python3
"""relay-bar: the Relay Bar surface (V2 steps 4-9).

A transient GTK3 window opened by the Ctrl+Alt+Space global shortcut. It:
  - captures a context snapshot BEFORE taking focus (V2 "Ortak Context
    Engine"): active app/title, selected text
  - shows the action set, the live context line, a free-text entry, settings
  - runs Relay Actions via the common action model (_relay_actions +
    _voxtype_groq), honoring cloud_processing and context_sharing
  - shows a Preview with [Apply][Copy][Retry][Cancel]; Apply re-verifies the
    target (stale-target check) and falls back to Copy (V2 "Preview ve Apply")
  - clears the temporary context snapshot on exit (no persistent memory)

Direct hotkeys share the same runner:
  relay-bar --action rewrite
  relay-bar --action summarize

Opens instantly -- no model or network call blocks the window (V2 invariant).

CLI:
  relay-bar              open the window (requires a display)
  relay-bar --action ID  run one action on the current selection (preview)
  relay-bar --actions    print action ids, one per line, no display needed
  relay-bar --version    print installed version
  relay-bar --settings   open settings dialog
"""
import argparse
import os
import sys
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import _relay_actions as actions  # noqa: E402
import _relay_context as context  # noqa: E402
import _relay_settings as settings  # noqa: E402


def _print_actions() -> int:
    for aid in actions.action_ids():
        print(aid)
    return 0


def _installed_version() -> str:
    cfg = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "relay" / "version"
    if cfg.exists():
        return cfg.read_text(encoding="utf-8").strip() or "unknown"
    return "unknown"


_BAR_CSS = b"""
#relay-bar .relay-prompt { font-size: 15px; font-weight: 600; }
#relay-bar .relay-context { font-size: 11px; }
#relay-bar .relay-hint { font-size: 10px; }
#relay-bar entry { padding: 8px 10px; font-size: 14px; border-radius: 8px; }
#relay-bar button { padding: 6px 14px; font-size: 13px; border-radius: 8px; }
#relay-bar .relay-settings-btn { padding: 6px 8px; }
#relay-preview textview { font-size: 13px; }
"""


def _install_css() -> None:
    """Theme-agnostic polish: spacing, radius, font sizes only. Colors come
    from the system theme (dim-label / suggested-action classes)."""
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk, Gdk  # noqa: E402
    provider = Gtk.CssProvider()
    provider.load_from_data(_BAR_CSS)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(), provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)


def _pretty_app(app: str) -> str:
    """Friendly app name from WM_CLASS tokens
    ("ghostty com.mitchellh.ghostty" -> "Ghostty")."""
    toks = [t for t in (app or "").split() if t]
    if not toks:
        return "Unknown app"
    plain = [t for t in toks if "." not in t]
    pick = plain[0] if plain else toks[-1].rsplit(".", 1)[-1]
    return pick[:1].upper() + pick[1:]


def _copy_to_clipboard(text: str) -> bool:
    """Write text to the X clipboard (CLIPBOARD selection). Returns success."""
    import subprocess  # noqa: E402
    for tool, cmd in (("xclip", ["xclip", "-selection", "clipboard"]),
                      ("wl-copy", ["wl-copy"])):
        if subprocess.run(["sh", "-c", f"command -v {tool}"],
                          capture_output=True).returncode == 0:
            try:
                subprocess.run(cmd, input=text.encode(), timeout=2.0)
                return True
            except Exception:
                pass
    return False


def _trigger_paste() -> None:
    """Run voxtype-paste-active to paste the clipboard into the active window
    (terminal-aware Ctrl+V vs Ctrl+Shift+V)."""
    import shutil  # noqa: E402
    import subprocess  # noqa: E402
    helper = shutil.which("voxtype-paste-active")
    if not helper:
        local = Path(__file__).with_name("voxtype-paste-active")
        if local.exists():
            helper = str(local)
    if helper:
        try:
            subprocess.run([helper], timeout=5.0,
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception:
            pass


def _notify(title: str, body: str) -> None:
    import subprocess  # noqa: E402
    try:
        subprocess.run(
            ["notify-send", "--app-name=relay", title, body],
            timeout=3.0, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    except Exception:
        pass


def _apply_result(text: str, snapshot: dict) -> None:
    """Apply an action result with the V2 stale-target contract.

    match    -> paste into the target (clipboard + voxtype-paste-active)
    changed  -> copy to clipboard + notify "source changed"
    unknown  -> copy to clipboard + notify (target unverifiable)
    Never force-focus the old window; never lose the result (V2).
    """
    _copy_to_clipboard(text)
    verdict = context.verify_target(snapshot)
    if verdict == "match":
        _trigger_paste()
        _notify("Relay", "Applied to target")
    elif verdict == "changed":
        _notify("Relay", "Source changed; result copied to clipboard")
    else:
        _notify("Relay", "Result copied to clipboard (target unverifiable)")


def _run_action_threaded(action_id, input_text, snapshot, cfg, on_done,
                         instruction=""):
    """Run a Relay Action in a background thread; call on_done(output, error)
    on the GTK main thread via GLib.idle_add."""
    import threading  # noqa: E402
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import GLib  # noqa: E402

    ctx_text = context.context_text_for_model(
        snapshot, settings.context_sharing_enabled(cfg))
    image_b64 = context.context_image_b64(
        snapshot, settings.context_sharing_enabled(cfg))

    def _work():
        import _voxtype_groq as groq  # noqa: E402
        out, err = actions.run_action(
            action_id, input_text, groq,
            context_text=ctx_text,
            cloud_processing=settings.cloud_processing_enabled(cfg),
            context_sharing=settings.context_sharing_enabled(cfg),
            image_b64=image_b64,
            text_model=settings.text_model(cfg),
            vision_model=settings.vision_model(cfg),
            instruction=instruction,
        )
        GLib.idle_add(lambda: on_done(out, err))

    threading.Thread(target=_work, daemon=True).start()


def _show_preview(action_id, output, snapshot, cfg, input_text="",
                  instruction=""):
    """Preview window with the result and Apply/Copy/Retry/Cancel per kind."""
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk, Gdk, GLib  # noqa: E402

    kind = (actions.action_by_id(action_id) or {}).get("kind", "transform")
    label = (actions.action_by_id(action_id) or {}).get("label", action_id)
    is_transform = kind in ("transform", "custom")

    win = Gtk.Window()
    win.set_name("relay-preview")
    win.set_title(f"Relay · {label}")
    win.set_default_size(620, 400)
    win.set_border_width(12)
    win.set_position(Gtk.WindowPosition.CENTER)
    win.set_keep_above(True)
    win.set_skip_taskbar_hint(True)
    destroy_handler = win.connect("destroy", lambda *_: Gtk.main_quit())
    win.connect("key-press-event", lambda _w, e: Gtk.main_quit()
                if e.keyval == Gdk.KEY_Escape else None)

    outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    win.add(outer)

    sw = Gtk.ScrolledWindow()
    sw.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
    tv = Gtk.TextView()
    tv.set_editable(False)
    tv.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
    tv.set_margin_start(8)
    tv.set_margin_end(8)
    tv.set_margin_top(8)
    tv.set_margin_bottom(8)
    tv.get_buffer().set_text(output)
    sw.add(tv)
    outer.pack_start(sw, True, True, 0)

    btnbox = Gtk.Box(spacing=8)
    outer.pack_start(btnbox, False, False, 4)

    def _copy(_):
        _copy_to_clipboard(output)
        _notify("Relay", "Result copied to clipboard")
        Gtk.main_quit()

    def _apply(_):
        # Hide the preview so focus returns to the target, then verify + apply.
        win.hide()
        GLib.timeout_add(300, lambda: (_apply_result(output, snapshot), Gtk.main_quit()))
        return True

    def _retry(_):
        win.disconnect(destroy_handler)
        win.destroy()
        if input_text:
            _show_working_then_run(action_id, input_text, snapshot, cfg,
                                   instruction=instruction)
        else:
            _build_bar_window(snapshot, cfg)

    if is_transform:
        b = Gtk.Button(label="Apply")
        b.get_style_context().add_class("suggested-action")
        b.connect("clicked", _apply)
        btnbox.pack_start(b, False, False, 0)
    b = Gtk.Button(label="Copy")
    b.connect("clicked", _copy)
    btnbox.pack_start(b, False, False, 0)
    b = Gtk.Button(label="Retry")
    b.connect("clicked", _retry)
    btnbox.pack_start(b, False, False, 0)
    b = Gtk.Button(label="Cancel")
    b.connect("clicked", lambda *_: Gtk.main_quit())
    btnbox.pack_start(b, False, False, 0)

    win.show_all()


def _build_model_combo(cfg_value: str, placeholder: str, groq_cfg: dict):
    """Return a ComboBoxText with [Auto / Recommended] + fetched Groq models."""
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk, GLib  # noqa: E402
    import _voxtype_groq as groq  # noqa: E402

    combo = Gtk.ComboBoxText(has_entry=True)
    combo.set_entry_text_column(0)
    combo.append("", f"Auto / Recommended: {placeholder}")

    def _populate():
        models = groq.list_models(groq_cfg)
        def _on_done():
            for m in models:
                combo.append(m["id"], m["id"])
            combo.show_all()
        GLib.idle_add(_on_done)

    import threading  # noqa: E402
    threading.Thread(target=_populate, daemon=True).start()

    if cfg_value:
        combo.get_child().set_text(cfg_value)

    return combo


def _model_value(combo) -> str:
    """Return the active text (user-typed or selected) stripped."""
    child = combo.get_child()
    return child.get_text().strip() if child else ""


def _show_settings_dialog(parent, cfg):
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk  # noqa: E402
    import _voxtype_groq as groq  # noqa: E402

    dlg = Gtk.Dialog(title="Relay Settings", transient_for=parent, modal=True)
    dlg.add_buttons("Close", Gtk.ResponseType.CLOSE)

    box = dlg.get_content_area()
    box.set_spacing(8)
    box.set_border_width(12)

    groq_cfg = groq.load_config("groq").get("groq", {})

    cloud = Gtk.CheckButton(label="Cloud processing (send text to the remote model)")
    cloud.set_active(settings.cloud_processing_enabled(cfg))
    ctx = Gtk.CheckButton(
        label="Context sharing (send screenshot/app/title/selection to the model)")
    ctx.set_active(bool(cfg.get("context_sharing", True)))
    consent = Gtk.CheckButton(label="I have consented to context sharing")
    consent.set_active(bool(cfg.get("context_sharing_consented", False)))
    right_visual = Gtk.CheckButton(
        label="Right Ctrl visual context (capture after transcription)")
    right_visual.set_active(cfg.get("right_ctrl_visual_context", False))

    text_model = _build_model_combo(
        settings.text_model(cfg), groq.DEFAULT_MODEL, groq_cfg)
    vision_model = _build_model_combo(
        settings.vision_model(cfg), groq.DEFAULT_VISION_MODEL, groq_cfg)

    box.pack_start(Gtk.Label(label="<b>Privacy (V2)</b>", use_markup=True), False, False, 0)
    box.pack_start(cloud, False, False, 0)
    box.pack_start(ctx, False, False, 0)
    box.pack_start(consent, False, False, 0)
    box.pack_start(Gtk.Label(
        label="Turning context sharing off does not change cloud processing. "
              "When cloud processing is off, remote Actions are unavailable."), False, False, 0)
    box.pack_start(Gtk.Separator(), False, False, 4)
    box.pack_start(Gtk.Label(label="<b>Models</b>", use_markup=True), False, False, 0)
    box.pack_start(Gtk.Label(label="Text model (empty = Auto / Recommended)"), False, False, 0)
    box.pack_start(text_model, False, False, 0)
    box.pack_start(Gtk.Label(label="Vision model (empty = Auto / Recommended)"), False, False, 0)
    box.pack_start(vision_model, False, False, 0)
    box.pack_start(Gtk.Separator(), False, False, 4)
    box.pack_start(Gtk.Label(label="<b>Direct dictation</b>", use_markup=True), False, False, 0)
    box.pack_start(right_visual, False, False, 0)
    box.pack_start(Gtk.Label(
        label="Optional and privacy-gated: only runs when Context sharing and "
              "consent are both on. VoxType has no pre-record hook, so the "
              "active window is captured after transcription."), False, False, 0)

    def _on_response(d, _response):
        text_value = _model_value(text_model)
        vision_value = _model_value(vision_model)
        invalid = [
            label for label, value in (
                ("Text model", text_value),
                ("Vision model", vision_value),
            )
            if not settings.valid_model_id(value, allow_empty=True)
        ]
        if invalid:
            err = Gtk.MessageDialog(
                transient_for=d, modal=True,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.CLOSE,
                text="Invalid model ID",
            )
            err.format_secondary_text(
                f"{', '.join(invalid)} must contain only letters, numbers, "
                "dots, underscores, slashes, or hyphens (max 200 chars).")
            err.run()
            err.destroy()
            return

        new = dict(cfg)
        new["cloud_processing"] = cloud.get_active()
        new["context_sharing"] = ctx.get_active()
        new["context_sharing_consented"] = consent.get_active()
        new["text_model"] = text_value
        new["vision_model"] = vision_value
        new["right_ctrl_visual_context"] = right_visual.get_active()
        settings.save(new)
        cfg.clear()
        cfg.update(new)
        d.destroy()

    dlg.connect("response", _on_response)
    dlg.show_all()
    return dlg


def _consent_first_use(parent, snapshot, cfg):
    """If context exists and consent is missing, ask once (V2 first-use)."""
    if cfg.get("context_sharing_consented"):
        return cfg
    has_ctx = bool(snapshot.get("app") or snapshot.get("has_selection"))
    if not has_ctx:
        return cfg
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk  # noqa: E402

    dlg = Gtk.MessageDialog(
        transient_for=parent, modal=True,
        message_type=Gtk.MessageType.QUESTION,
        buttons=Gtk.ButtonsType.YES_NO,
        text="Allow context sharing?",
    )
    dlg.format_secondary_text(
        "Relay can send your active window screenshot, app name, title, and "
        "selected text to the model to improve results. This is data only - "
        "never treated as instructions. Cloud processing is separate. Allow?")
    resp = dlg.run()
    dlg.destroy()
    if resp == Gtk.ResponseType.YES:
        cfg = settings.consent_to_context_sharing()
    else:
        # Respect the decline: consent stays false, context sharing off.
        cfg = dict(cfg)
        cfg["context_sharing_consented"] = False
        cfg["context_sharing"] = False
        settings.save(cfg)
    return cfg


def _prompt_instruction(parent, initial="") -> str | None:
    """Ask for a Custom Action instruction. Returns None if cancelled."""
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk, Gdk  # noqa: E402

    dlg = Gtk.Dialog(title="Custom Action", transient_for=parent, modal=True)
    dlg.set_default_size(480, -1)
    dlg.add_buttons(
        "Cancel", Gtk.ResponseType.CANCEL,
        "Run", Gtk.ResponseType.OK,
    )
    dlg.set_default_response(Gtk.ResponseType.OK)
    run_btn = dlg.get_widget_for_response(Gtk.ResponseType.OK)
    if run_btn:
        run_btn.get_style_context().add_class("suggested-action")

    box = dlg.get_content_area()
    box.set_spacing(8)
    box.set_border_width(12)
    box.pack_start(Gtk.Label(
        label="What should I do with this text?",
        halign=Gtk.Align.START,
    ), False, False, 0)

    entry = Gtk.Entry()
    entry.set_text(initial)
    entry.set_placeholder_text("e.g. Make it a polite email, convert to bullets…")
    entry.set_activates_default(True)
    box.pack_start(entry, False, False, 0)

    dlg.connect("key-press-event", lambda _w, e: dlg.response(Gtk.ResponseType.CANCEL)
                if e.keyval == Gdk.KEY_Escape else None)
    dlg.show_all()
    entry.grab_focus()
    resp = dlg.run()
    text = entry.get_text().strip()
    dlg.destroy()
    if resp != Gtk.ResponseType.OK:
        return None
    return text


_MNEMONICS = {
    "dictate": "_Dictate",
    "rewrite": "_Rewrite",
    "summarize": "_Summarize",
    "custom": "_Custom Action",
}


def _build_bar_window(snapshot, cfg):
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk, Gdk  # noqa: E402

    win = Gtk.Window()
    win.set_name("relay-bar")
    win.set_title("Relay")
    win.set_default_size(600, -1)
    win.set_resizable(False)
    win.set_border_width(16)
    win.set_position(Gtk.WindowPosition.CENTER)
    win.set_keep_above(True)
    win.set_skip_taskbar_hint(True)
    win.set_type_hint(Gdk.WindowTypeHint.DIALOG)
    win.connect("destroy", lambda *_: Gtk.main_quit())
    win.connect("key-press-event", lambda _w, e: Gtk.main_quit()
                if e.keyval == Gdk.KEY_Escape else None)

    outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
    win.add(outer)

    prompt = Gtk.Label(label="Ne yapmak istiyorsun?")
    prompt.set_halign(Gtk.Align.START)
    prompt.get_style_context().add_class("relay-prompt")
    outer.pack_start(prompt, False, False, 0)

    sel_part = "Selected text" if snapshot.get("has_selection") else "No selection"
    img_part = "Image" if snapshot.get("has_image") else "No image"
    ctx_line = f"{_pretty_app(snapshot.get('app', ''))} · {sel_part} · {img_part}"
    clabel = Gtk.Label(label=ctx_line)
    clabel.set_halign(Gtk.Align.START)
    clabel.get_style_context().add_class("dim-label")
    clabel.get_style_context().add_class("relay-context")
    outer.pack_start(clabel, False, False, 0)

    if snapshot.get("warnings"):
        wlbl = Gtk.Label(label="⚠ " + "; ".join(snapshot["warnings"]))
        wlbl.set_halign(Gtk.Align.START)
        wlbl.get_style_context().add_class("dim-label")
        outer.pack_start(wlbl, False, False, 0)

    entry = Gtk.Entry()
    entry.set_text(snapshot.get("selection", "") if snapshot.get("has_selection") else "")
    entry.set_placeholder_text("Write or paste text, then pick an action")
    outer.pack_start(entry, False, False, 0)

    btnbox = Gtk.Box(spacing=8)
    outer.pack_start(btnbox, False, False, 4)

    def _start(a, instruction=""):
        input_text = entry.get_text().strip() or snapshot.get("selection", "")
        if a["id"] == "dictate":
            import subprocess  # noqa: E402
            try:
                subprocess.Popen(actions.dictation_command(),
                                 stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            except Exception:
                pass
            Gtk.main_quit()
            return
        if not input_text:
            _notify("Relay", "No input text")
            return
        if a["id"] == "custom" and not instruction:
            instruction = _prompt_instruction(win) or ""
            if not instruction:
                return
        # Hide the bar so focus returns to the target before the action
        # and before the preview's stale-target check.
        win.hide()
        _show_working_then_run(a["id"], input_text, snapshot, cfg,
                               instruction=instruction)

    def _on_action(a):
        return lambda _: _start(a)

    for a in actions.visible_actions():
        b = Gtk.Button.new_with_mnemonic(_MNEMONICS.get(a["id"], a["label"]))
        b.connect("clicked", _on_action(a))
        btnbox.pack_start(b, False, False, 0)

    settings_btn = Gtk.Button()
    settings_btn.set_image(Gtk.Image.new_from_icon_name(
        "emblem-system-symbolic", Gtk.IconSize.BUTTON))
    settings_btn.set_tooltip_text("Settings")
    settings_btn.set_relief(Gtk.ReliefStyle.NONE)
    settings_btn.get_style_context().add_class("relay-settings-btn")
    settings_btn.connect("clicked", lambda *_: _show_settings_dialog(win, cfg))
    btnbox.pack_end(settings_btn, False, False, 0)

    hint = Gtk.Label(label="Enter: Rewrite · Alt+D/R/S/C: actions · Esc: kapat")
    hint.set_halign(Gtk.Align.START)
    hint.get_style_context().add_class("dim-label")
    hint.get_style_context().add_class("relay-hint")
    outer.pack_start(hint, False, False, 0)

    rewrite = actions.action_by_id("rewrite")
    if rewrite:
        entry.connect("activate", lambda *_: _start(rewrite))

    win.show_all()
    entry.grab_focus()
    if entry.get_text():
        entry.select_region(0, -1)
    return win


def _show_working_then_run(action_id, input_text, snapshot, cfg, instruction=""):
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk  # noqa: E402

    work = Gtk.Window()
    work.set_name("relay-working")
    work.set_title("Relay")
    work.set_position(Gtk.WindowPosition.CENTER)
    work.set_keep_above(True)
    work.set_decorated(False)
    work.set_resizable(False)
    box = Gtk.Box(spacing=10)
    box.set_border_width(16)
    spinner = Gtk.Spinner()
    spinner.start()
    box.pack_start(spinner, False, False, 0)
    box.pack_start(Gtk.Label(label="Processing…"), False, False, 0)
    work.add(box)
    work.show_all()

    def _on_done(output, err):
        work.destroy()
        if err:
            _notify("Relay", f"Action failed: {err}")
            Gtk.main_quit()
            return
        _show_preview(action_id, output, snapshot, cfg,
                      input_text=input_text, instruction=instruction)
    _run_action_threaded(action_id, input_text, snapshot, cfg, _on_done,
                         instruction=instruction)


def _open_settings_only() -> None:
    """Open the settings dialog standalone (relay-bar --settings)."""
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk  # noqa: E402
    Gtk.init()
    _install_css()
    cfg = settings.load()
    dlg = _show_settings_dialog(None, cfg)
    dlg.connect("response", lambda *_: Gtk.main_quit())
    Gtk.main()


def _run_direct_action(action_id: str) -> int:
    """Hotkey path: capture context, run one action, show shared preview."""
    if action_id not in actions.ACTION_SPECS:
        print(f"relay-bar: unknown action {action_id!r}", file=sys.stderr)
        return 2
    if not os.environ.get("DISPLAY") and not os.environ.get("WAYLAND_DISPLAY"):
        print("relay-bar: no display found (DISPLAY/WAYLAND_DISPLAY unset)", file=sys.stderr)
        return 1

    import atexit  # noqa: E402
    import signal  # noqa: E402
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk  # noqa: E402
    Gtk.init()
    _install_css()

    context.clear_snapshot()
    atexit.register(context.clear_snapshot)

    def _on_sigterm(signum, frame):
        context.clear_snapshot()
        raise SystemExit(0)
    signal.signal(signal.SIGTERM, _on_sigterm)
    signal.signal(signal.SIGINT, _on_sigterm)

    snapshot = context.capture_snapshot()
    context.save_snapshot(snapshot)
    cfg = settings.load()

    input_text = (snapshot.get("selection") or "").strip()
    if not input_text:
        _notify("Relay", "No input text")
        context.clear_snapshot()
        return 1

    updated_cfg = _consent_first_use(None, snapshot, cfg)
    if updated_cfg is not cfg:
        cfg.clear()
        cfg.update(updated_cfg)

    _show_working_then_run(action_id, input_text, snapshot, cfg)
    Gtk.main()
    context.clear_snapshot()
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(prog="relay-bar", description="Relay Bar surface")
    parser.add_argument("--actions", action="store_true",
                        help="print action ids and exit (no display needed)")
    parser.add_argument("--version", action="store_true",
                        help="print installed version and exit")
    parser.add_argument("--settings", action="store_true",
                        help="open the settings dialog and exit")
    parser.add_argument("--action", metavar="ID",
                        help="run one action on the current selection (rewrite|summarize|custom)")
    args = parser.parse_args()

    if args.version:
        print(_installed_version())
        return 0
    if args.actions:
        return _print_actions()
    if args.settings:
        _open_settings_only()
        return 0
    if args.action:
        return _run_direct_action(args.action.strip())

    if not os.environ.get("DISPLAY") and not os.environ.get("WAYLAND_DISPLAY"):
        print("relay-bar: no display found (DISPLAY/WAYLAND_DISPLAY unset)", file=sys.stderr)
        return 1

    import atexit  # noqa: E402
    import signal  # noqa: E402
    import gi  # noqa: E402
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk  # noqa: E402
    Gtk.init()
    _install_css()

    # Clear any stale snapshot from a previous crash/logout first, then never
    # let the temp context persist (V2: "Gecici context kalici hafizaya
    # donusturulmemeli"). atexit + SIGTERM both clear on the way out.
    context.clear_snapshot()
    atexit.register(context.clear_snapshot)

    def _on_sigterm(signum, frame):
        context.clear_snapshot()
        raise SystemExit(0)
    signal.signal(signal.SIGTERM, _on_sigterm)
    signal.signal(signal.SIGINT, _on_sigterm)

    # Capture context BEFORE the window takes focus (V2 invariant).
    snapshot = context.capture_snapshot()
    context.save_snapshot(snapshot)
    cfg = settings.load()

    win = _build_bar_window(snapshot, cfg)
    updated_cfg = _consent_first_use(win, snapshot, cfg)
    if updated_cfg is not cfg:
        cfg.clear()
        cfg.update(updated_cfg)

    Gtk.main()
    # Clear the temporary context snapshot on exit (V2: no persistent memory).
    context.clear_snapshot()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
