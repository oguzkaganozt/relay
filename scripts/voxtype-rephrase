#!/usr/bin/env python3
"""Thin wrapper: Ctrl+Alt+R runs the shared Relay rewrite path (preview + Apply)."""
import os
import shutil
import sys
from pathlib import Path


def _relay_bar() -> str | None:
    local = Path(__file__).resolve().with_name("relay-bar")
    if local.exists():
        return str(local)
    return shutil.which("relay-bar")


def main() -> int:
    bar = _relay_bar()
    if not bar:
        print("voxtype-rephrase: relay-bar not found", file=sys.stderr)
        return 127
    os.execv(bar, [bar, "--action", "rewrite"])


if __name__ == "__main__":
    raise SystemExit(main())
