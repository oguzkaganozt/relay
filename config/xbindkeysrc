# Relay: open the Relay Bar
"$HOME/.local/bin/relay-bar"
    ${RELAY_BAR_BIND}

# Relay: rephrase selected text
# NOTE: the key bindings below are template variables resolved by install.sh.
# $HOME is expanded by xbindkeys at runtime.
"$HOME/.local/bin/voxtype-rephrase"
    ${REPHRASE_BIND}

# Relay: summarize selected text
"$HOME/.local/bin/voxtype-summarize"
    ${SUMMARIZE_BIND}
