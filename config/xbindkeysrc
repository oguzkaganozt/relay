# Relay: open the Relay Bar
"$HOME/.local/bin/relay-bar"
    ${RELAY_BAR_BIND}

# Relay: rewrite selected text (shared bar runner + preview)
# NOTE: the key bindings below are template variables resolved by install.sh.
# $HOME is expanded by xbindkeys at runtime.
"$HOME/.local/bin/relay-bar --action rewrite"
    ${REPHRASE_BIND}

# Relay: summarize selected text (shared bar runner + preview)
"$HOME/.local/bin/relay-bar --action summarize"
    ${SUMMARIZE_BIND}
